# ─────────────────────────────────────────────────────────────────
# avantika-secretary-ai  —  Environment Variables
# Copy to .env for local dev.  Set in Azure App Settings for prod.
# ─────────────────────────────────────────────────────────────────

# ── AI Platform (REQUIRED in production) ─────────────────────────
# URL of the shared-ai-platform /api/chat endpoint
AI_PLATFORM_URL=https://your-shared-ai-platform.azurewebsites.net/api/chat

# Internal app key — must match one value in shared-ai-platform's AI_INTERNAL_APP_KEYS
# Sent as: X-Api-Key: <value>
AI_APP_KEY=your_internal_app_key_here

# Timeout in seconds for each AI request (default: 60)
AI_TIMEOUT_SECS=60

# Max tokens per AI response (default: 2048)
AI_MAX_TOKENS=2048

# ── Anthropic (LOCAL DEV ONLY — not used when AI_PLATFORM_URL is set) ──
# Falls back to direct Anthropic only when AI_PLATFORM_URL is missing
ANTHROPIC_API_KEY=sk-ant-...your_key_here...

# ── Job Sources (legacy) ──────────────────────────────────────────
# Comma-separated job feed URLs (defaults used when empty)
# Defaults: arbeitnow.com/api/job-board-api, himalayas.app/jobs/api?limit=20
JOB_FEED_URLS=

# ── Remote Job Discovery Module ───────────────────────────────────
# Remotive: FREE, no key needed — always active
# https://remotive.com/api/remote-jobs  (software-dev category)

# Adzuna Developer API — register free at https://developer.adzuna.com/
# Searches GB, DE, NL, IE for Java/Spring remote jobs
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# JSearch via RapidAPI — https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Freemium: 200 req/month free. Searches remote Java contract jobs globally.
RAPIDAPI_KEY=your_rapidapi_key_here

# ── WhatsApp / Twilio ─────────────────────────────────────────────
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_WEBHOOK_SECRET=

# ── Travel API ───────────────────────────────────────────────────
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret

# ── App Behaviour ─────────────────────────────────────────────────
PLAYWRIGHT_HEADLESS=true

# ─────────────────────────────────────────────────────────────────
# shared-ai-platform  —  vars that live ONLY on that app (DO NOT add here)
# AI_REQUIRE_APP_KEY, AI_INTERNAL_APP_KEYS, ANTHROPIC_API_KEY (platform copy),
# OLLAMA_BASE_URL, MODEL_ROUTING_CONFIG, etc.
# ─────────────────────────────────────────────────────────────────
